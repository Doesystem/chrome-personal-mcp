# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

MODE=prod               # prod | debug
TRANSPORT=http          # http | stdio
HTTP_PORT=3000
MCP_SECRET=             # set a strong secret token
VNC_PASSWORD=           # VNC password (debug mode only)
TOOL_TIMEOUT_MS=30000   # global tool timeout in ms (default 30s)
ALLOWED_ORIGINS=        # comma-separated allowed origins, empty = allow all
                        # e.g. http://localhost:5678,https://n8n.example.com
